{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://pociag-do-predykcji/schemas/route",
    "title": "Route",
    "description": "A train route from the PLK timetable (schedule)",
    "type": "object",
    "required": [
        "id",
        "schedule_id",
        "order_id",
        "created_at",
        "updated_at"
    ],
    "properties": {
        "id": {
            "type": "integer",
            "format": "int64",
            "description": "Surrogate primary key"
        },
        "schedule_id": {
            "type": "integer",
            "format": "int32",
            "description": "PLK schedule ID (yearly number, e.g. 25 = 2025/2026)"
        },
        "order_id": {
            "type": "integer",
            "format": "int32",
            "description": "PLK order ID (stable within a schedule)"
        },
        "train_order_id": {
            "type": "integer",
            "format": "int32",
            "description": "Train order ID (when different from order_id)"
        },
        "name": {
            "type": "string",
            "description": "Train name (e.g. 'IC Polonez')"
        },
        "carrier_code": {
            "type": "string",
            "description": "Carrier code (e.g. 'IC', 'KM', 'KS')"
        },
        "national_number": {
            "type": "string",
            "description": "National train number"
        },
        "international_arrival_num": {
            "type": "string",
            "description": "International arrival number"
        },
        "international_departure_num": {
            "type": "string",
            "description": "International departure number"
        },
        "commercial_category_symbol": {
            "type": "string",
            "description": "Commercial category symbol (EIC, IC, TLK, REG, etc.)"
        },
        "created_at": {
            "type": "string",
            "format": "date-time"
        },
        "updated_at": {
            "type": "string",
            "format": "date-time"
        }
    },
    "additionalProperties": false
}