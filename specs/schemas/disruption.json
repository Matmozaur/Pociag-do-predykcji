{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://pociag-do-predykcji/schemas/disruption",
    "title": "Disruption",
    "description": "A traffic disruption on the railway network",
    "type": "object",
    "required": [
        "id",
        "external_disruption_id",
        "created_at",
        "updated_at"
    ],
    "properties": {
        "id": {
            "type": "integer",
            "format": "int64",
            "description": "Surrogate primary key"
        },
        "external_disruption_id": {
            "type": "integer",
            "format": "int64",
            "description": "PLK disruption ID"
        },
        "disruption_type_code": {
            "type": "string",
            "description": "Disruption type code (e.g. 'utr_32')"
        },
        "start_station_ext_id": {
            "type": "integer",
            "format": "int32",
            "description": "PLK station ID for disruption start"
        },
        "end_station_ext_id": {
            "type": "integer",
            "format": "int32",
            "description": "PLK station ID for disruption end"
        },
        "message": {
            "type": "string",
            "description": "Disruption message text"
        },
        "date_from": {
            "type": "string",
            "format": "date",
            "description": "Disruption start date"
        },
        "date_to": {
            "type": "string",
            "format": "date",
            "description": "Disruption end date"
        },
        "created_at": {
            "type": "string",
            "format": "date-time"
        },
        "updated_at": {
            "type": "string",
            "format": "date-time"
        }
    },
    "additionalProperties": false
}