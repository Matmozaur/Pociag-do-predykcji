# Copy this file to infra/.env and fill in real values.
# docker compose reads this file automatically from the infra/ directory.

# ── PLK Open Data API ─────────────────────────────────────────────────────────
PLK_BASE_URL=https://pdp-api.plk-sa.pl
PLK_API_KEY=replace_with_your_real_api_key

# ── PostgreSQL (main database) ────────────────────────────────────────────────
POSTGRES_PASSWORD=pociag_dev_secret

# ── MinIO (S3-compatible object storage) ──────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_DB_PASSWORD=airflow_dev_secret
AIRFLOW__CORE__FERNET_KEY=YlCImzjge_TeZc7jPJ7Jz2pgOtb4yTssA1pVyqIADWg=
