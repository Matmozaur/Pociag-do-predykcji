# Copy this file to infra/.env and fill in real values.

# PLK Open Data API base URL
PLK_BASE_URL=https://api.rozklad-pkp.pl

# PLK Open Data API key
PLK_API_KEY=replace_with_your_real_api_key

# Optional: override local Postgres password used by compose
POSTGRES_PASSWORD=pociag_dev_secret

# Optional but recommended: stable Airflow webserver secret key for sessions/CSRF
AIRFLOW__WEBSERVER__SECRET_KEY=change_me_to_a_long_random_value
