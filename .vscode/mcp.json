{
	"servers": {
		"playwright": {
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"type": "stdio"
		},
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-p",
				"127.0.0.1:8085:8085",
				"-e",
				"GITHUB_OAUTH_CALLBACK_PORT=8085",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:1.5.0"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.5.0"
		},
		"io.github.bytebase/dbhub": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@bytebase/dbhub@0.23.0"
			],
			"env": {
				"DSN": "${input:DSN}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.23.0"
		},
		"context7": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp"
			]
		}
	},
	"inputs": [
		{
			"id": "token",
			"type": "promptString",
			"description": "GitHub personal access token",
			"password": true
		},
		{
			"id": "DSN",
			"type": "promptString",
			"description": "Postgres connection string (e.g. postgres://user:pass@localhost:5432/pociag)",
			"password": true
		}
	]
}